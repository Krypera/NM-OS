[Unit]
Description=NM-OS network bootstrap gate
After=nmos-boot-profile.service
Wants=nmos-boot-profile.service

[Service]
Type=simple
ExecStart=/usr/local/lib/nmos/network_bootstrap.py
Restart=on-failure
RestartSec=5
TimeoutStartSec=320
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
